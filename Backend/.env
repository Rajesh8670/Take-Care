JWT_SECRET=your_super_secret_key_that_is_long_and_random

# Node Environment
NODE_ENV=production

# Brevo API Configuration (HTTP API - works on Render free tier)
# Get your API key from: https://app.brevo.com/settings/keys/api
# API key must start with 'xkeysib-' (NOT 'xsmtpsib-')
# Set this environment variable on Render dashboard (not in version control)
BREVO_API_KEY=${BREVO_API_KEY}
FROM_EMAIL=${FROM_EMAIL}

# Frontend Base URL
VITE_API_BASE_URL=https://take-care-backend.onrender.com
